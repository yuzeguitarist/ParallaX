[Unit]
# ParallaX distributed-fuzz — drives plx-sync.service on a ~10 min cadence.
# RandomizedDelaySec staggers the three boxes so their Release ops don't collide.
Description=ParallaX fuzz corpus sync timer (~10 min)

[Timer]
Unit=plx-sync.service
# First sync shortly after boot, then every 10 minutes of active time.
OnBootSec=3min
OnUnitActiveSec=10min
RandomizedDelaySec=120
Persistent=true

[Install]
WantedBy=timers.target
