.DS_Store
.cursor/
.claude/worktrees/
.claude/
.devin/
target/
docs/
code_refs/

# Local secrets generated by plx init/deploy. Never commit these.
parallax.toml
parallax.server.toml
parallax.client.toml
# Referenced/sealed secret material (plx init --default, plx seal). Never commit.
*.secrets.toml
*.secrets.enc
host.key
audits/

# cargo-mutants output (nightly-mutants CI uploads it as an artifact; local
# `cargo mutants` runs leave these dirs behind).
mutants.out/
mutants.out.old/

# Python bytecode cache (scripts/wiki_sync/ is stdlib-only Python); never commit.
__pycache__/
*.pyc